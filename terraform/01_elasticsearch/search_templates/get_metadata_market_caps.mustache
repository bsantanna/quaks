{
  "size": 0,
  "query": {
    "bool": {
      "must": [
        { "terms": { "key_ticker": {{#toJson}}key_tickers{{/toJson}} } }
      ]
    }
  },
  "aggs": {
    "by_ticker": {
      "terms": {
        "field": "key_ticker",
        "size": {{size}}
      },
      "aggs": {
        "latest": {
          "top_hits": {
            "size": 1,
            "_source": ["market_capitalization"]
          }
        }
      }
    }
  }
}
